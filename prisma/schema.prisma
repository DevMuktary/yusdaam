generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  ADMIN
  ASSET_OWNER // Changed from INVESTOR for compliance
  RIDER
}

enum AccountStatus {
  PENDING             // Default for new registrations
  AWAITING_SIGNATURE  // Vehicle assigned, waiting for owner to sign
  ACTIVE              // Fully operational dashboard
  APPROVED         
  REJECTED
  SUSPENDED
}

enum VehicleType {
  TRICYCLE
  CAR_UBER
  MOTORCYCLE
  MINIBUS_KOROPE
  TIPPER
  OTHERS
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  UNASSIGNED
}

enum GuarantorStatus {
  PENDING     // Link generated, waiting for guarantor to fill
  SUBMITTED   // Guarantor filled it, waiting for admin review
  VERIFIED    // Admin approved this guarantor
  REJECTED    // Admin rejected this guarantor
}

// --- NEXTAUTH MODELS ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- CORE APPLICATION MODELS ---
model User {
  id               String        @id @default(cuid())
  
  // Standard NextAuth fields
  name             String?       // Can be auto-populated as firstName + lastName
  email            String?       @unique
  emailVerified    DateTime?
  image            String?
  
  // Custom Registration Fields
  password         String?       // Required for Credentials login
  firstName        String?
  lastName         String?
  middleName       String?
  
  // Location (Diaspora Support)
  country          String        @default("Nigeria")
  state            String?
  streetAddress    String?
  
  // Contact
  phoneCountryCode String        @default("+234")
  phoneNumber      String?       @unique
  
  // KYC 
  nin              String?
  bvn              String?       
  passportUrl      String?       
  utilityBillUrl   String?       
  signatureUrl     String?       // Stores the virtual agreement signature
  hpaAgreementUrl  String?
  poaAgreementUrl  String?

  // --- NEW: RIDER LICENSING & OPS DATA ---
  driversLicenseNo       String?
  lasdriNo               String?
  driversLicenseUrl      String?
  drivingExperienceYears String?
  rideHailingActive      Boolean? @default(false)
  previousHPExperience   Boolean? @default(false)
  
  // Next of Kin
  nokFirstName     String?
  nokLastName      String?
  nokRelationship  String?
  nokPhone         String?
  nokAddress       String?       
  nokIdNumber      String?       
  
  // Financial Routing (Payouts)
  bankName         String?
  bankCode         String?
  accountNumber    String?
  accountName      String?

  // --- NEW: PAYSTACK VIRTUAL ACCOUNT DATA ---
  paystackCustomerCode String?
  virtualAccountNo     String?
  virtualBankName      String?
  virtualAccountName   String?
  
  // Pre-Qualification Intents
  preferredAssetClass String?
  intendedVolume      String?

  // Authorization & Roles
  role             Role          @default(ASSET_OWNER)
  accountStatus    AccountStatus @default(PENDING) 

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  accounts         Account[]
  sessions         Session[]
  
  // Relations based on roles
  ownedVehicles    Vehicle[]     @relation("AssetOwnerVehicles")
  assignedTrip     Vehicle?      @relation("RiderVehicle")
  contracts        Contract[]
  transactions     Ledger[]
  guarantors       Guarantor[]   // Link to their guarantors
}

// --- GUARANTOR MODEL ---
model Guarantor {
  id               String          @id @default(cuid())
  riderId          String
  rider            User            @relation(fields: [riderId], references: [id], onDelete: Cascade)
  
  // Link Tracking
  token            String          @unique // e.g. /guarantor/abc123xyz
  status           GuarantorStatus @default(PENDING)
  
  // Initial Data (Provided by Rider)
  firstName        String
  lastName         String
  phone            String
  relationship     String
  
  // Full Data (Provided by Guarantor later via link)
  email            String?
  altPhone         String?
  nin              String?
  passportUrl      String?
  
  // Traceability
  address          String?
  residentialStatus String?      // e.g., Landlord, Tenant
  utilityBillUrl   String?
  
  // Occupational Capacity
  employmentStatus String?
  employerName     String?
  officeAddress    String?
  
  // Legal
  signatureUrl     String?       // The digital signature from the deed
  signedAt         DateTime?     // Exact timestamp of signing
  ipAddress        String?       // Legal trail

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Vehicle {
  id                 String        @id @default(cuid())
  type               VehicleType
  makeModel          String?       // e.g., "TVS King" or "Toyota Corolla"
  year               String?       // e.g., "2023"
  engineNumber       String?  
  customType         String?
  chassisNumber      String?        
  registrationNumber String        
  status             VehicleStatus @default(UNASSIGNED)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  ownerId            String?       
  owner              User?         @relation("AssetOwnerVehicles", fields: [ownerId], references: [id])
  
  riderId            String?       @unique
  rider              User?         @relation("RiderVehicle", fields: [riderId], references: [id])

  contract           Contract?
  ledgers            Ledger[]
}

model Contract {
  id                     String   @id @default(cuid())
  ownerId                String   
  vehicleId              String   @unique
  
  // --- RIDER TERMS ---
  totalHirePurchasePrice Float    // The total price the rider is buying it for
  downPayment            Float    @default(0) // What they paid upfront
  riderWeeklyRemittance  Float    // What the rider pays every week
  riderDurationWeeks     Int      // How many weeks the rider will pay

  // --- OWNER TERMS ---
  ownerWeeklyPayout      Float    // What the investor/owner receives weekly
  ownerDurationWeeks     Int      // How many weeks the owner receives this payout

  isActive               Boolean  @default(true)
  signedDocumentUrl      String?  
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  owner                  User     @relation(fields: [ownerId], references: [id])
  vehicle                Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Ledger {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // e.g., "PAYMENT_COLLECTED", "OWNER_REMITTANCE"
  reference   String   @unique // Paystack/Flutterwave transaction ref
  description String?
  date        DateTime @default(now())
  
  vehicleId   String
  ownerId     String   

  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  owner       User     @relation(fields: [ownerId], references: [id])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  ADMIN
  ASSET_OWNER // Changed from INVESTOR for SEC compliance
  RIDER
}

enum AccountStatus {
  PENDING     // Default for new registrations
  APPROVED    // Unlocks the dashboard
  REJECTED
  SUSPENDED
}

enum VehicleType {
  TRICYCLE
  CAR_UBER
  MOTORCYCLE
  MINIBUS_KOROPE
  TIPPER
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  UNASSIGNED
}

// --- NEXTAUTH MODELS ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- CORE APPLICATION MODELS ---
model User {
  id               String        @id @default(cuid())
  // Standard NextAuth fields
  name             String?       // Can be auto-populated as firstName + lastName
  email            String?       @unique
  emailVerified    DateTime?
  image            String?
  
  // Custom Registration Fields
  password         String?       // Required for Credentials login
  firstName        String?
  lastName         String?
  middleName       String?
  
  // Location (Diaspora Support)
  country          String        @default("Nigeria")
  state            String?
  streetAddress    String?
  
  // Contact
  phoneCountryCode String        @default("+234")
  phoneNumber      String?       @unique
  
  // KYC 
  nin              String?
  
  // Next of Kin
  nokFirstName     String?
  nokLastName      String?
  nokRelationship  String?
  nokPhone         String?
  
  // Financial Routing
  bankName         String?
  bankCode         String?
  accountNumber    String?
  accountName      String?
  
  // Pre-Qualification Intents
  preferredAssetClass String?
  intendedVolume      String?

  // Authorization & Roles
  role             Role          @default(ASSET_OWNER)
  accountStatus    AccountStatus @default(PENDING) // Locks them out until admin approves

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  accounts         Account[]
  sessions         Session[]
  
  // Relations based on roles
  ownedVehicles    Vehicle[]     @relation("AssetOwnerVehicles")
  assignedTrip     Vehicle?      @relation("RiderVehicle")
  contracts        Contract[]
  transactions     Ledger[]
}

model Vehicle {
  id                 String        @id @default(cuid())
  type               VehicleType
  registrationNumber String        @unique
  status             VehicleStatus @default(UNASSIGNED)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  ownerId            String?       // Changed from investorId
  owner              User?         @relation("AssetOwnerVehicles", fields: [ownerId], references: [id])
  
  riderId            String?       @unique
  rider              User?         @relation("RiderVehicle", fields: [riderId], references: [id])

  contract           Contract?
  ledgers            Ledger[]
}

model Contract {
  id                   String   @id @default(cuid())
  ownerId              String   // Changed from investorId
  vehicleId            String   @unique
  weeklyRemittance     Float    // SEC Compliant: Changed from guaranteedWeeklyReturn
  agreedDurationMonths Int
  isActive             Boolean  @default(true)
  signedDocumentUrl    String?  // URL to the AWS/Cloudinary PDF
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  owner                User     @relation(fields: [ownerId], references: [id])
  vehicle              Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Ledger {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // e.g., "PAYMENT_COLLECTED", "OWNER_REMITTANCE"
  reference   String   @unique // Paystack/Flutterwave transaction ref
  description String?
  date        DateTime @default(now())
  
  vehicleId   String
  ownerId     String   // Changed from investorId

  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  owner       User     @relation(fields: [ownerId], references: [id])
}
